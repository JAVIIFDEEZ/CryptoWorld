# ═══════════════════════════════════════════════════════════════════
# .env.example — Variables de entorno requeridas
#
# Copia este archivo a .env y rellena los valores:
#   cp .env.example .env
#
# NUNCA comitas el archivo .env real al repositorio.
# ═══════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-cambia-esto-en-produccion-con-clave-larga
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

# ── Base de datos PostgreSQL ──────────────────────────────────────
DB_NAME=cryptoworld_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── CORS ─────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173 http://127.0.0.1:5173

# ── Frontend ──────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api
FRONTEND_URL=http://localhost:5173

# ── Email (verificación y recuperación) ──────────────────────────
# Desarrollo local sin SMTP real: deja EMAIL_BACKEND en console para ver
# el enlace en los logs del contenedor backend.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Para enviar correos reales, usar SMTP y completar estos campos:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
